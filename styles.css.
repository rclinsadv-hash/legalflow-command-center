:root {
    --bg: #06060f;
    --surface: #0d0d1e;
    --surface2: #12122a;
    --border: rgba(139,92,246,0.15);
    --border-bright: rgba(139,92,246,0.4);
    --accent: #7c3aed;
    --accent2: #a855f7;
    --accent3: #c084fc;
    --gold: #f59e0b;
    --text: #e8e8f0;
    --text2: #9090b0;
    --text3: #5a5a7a;
    --green: #10b981;
    --red: #ef4444;
    --blue: #3b82f6;
    --sidebar-w: 260px;
    --glass: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.08);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'DM Sans', 'Outfit', sans-serif;
}

body {
    background: var(--bg);
    color: var(--text);
    overflow-x: hidden;
}

.app-container {
    display: flex;
    min-height: 100vh;
}

/* --- Sidebar --- */
.sidebar {
    position: fixed;
    left: 0; top: 0;
    width: var(--sidebar-w);
    height: 100vh;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    z-index: 100;
    overflow-y: auto;
}

.logo {
    padding: 28px 24px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-start;
}
.logo-text {
    font-family: 'DM Serif Display', serif;
    font-size: 26px;
    letter-spacing: -0.5px;
    background: linear-gradient(135deg, #a855f7, #c084fc, #f59e0b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
.logo-sub {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text3);
}

.nav-links {
    padding: 1rem;
    flex: 1;
}

.nav-btn {
    width: calc(100% - 16px);
    background: transparent;
    border: none;
    color: var(--text2);
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.15s;
    font-size: 13.5px;
    margin: 1px 8px;
    position: relative;
    text-align: left;
}

.nav-btn i {
    font-size: 16px;
    width: 20px;
    text-align: center;
}

.nav-btn:hover {
    background: rgba(124, 58, 237, 0.12);
    color: var(--text);
}

.nav-btn.active {
    background: rgba(124, 58, 237, 0.2);
    color: #c084fc;
    font-weight: 500;
}

.nav-btn.active::before {
    content: '';
    position: absolute;
    left: -8px;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 20px;
    background: var(--accent2);
    border-radius: 0 2px 2px 0;
}

.nav-divider {
    height: 1px;
    background: var(--glass-border);
    margin: 1.5rem 1rem;
}

.sidebar-footer {
    padding: 1.5rem;
    border-top: 1px solid var(--glass-border);
}

.user-info {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.avatar {
    width: 40px;
    height: 40px;
    background: var(--accent);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
}

.user-name { font-size: 0.9rem; font-weight: 600; }
.user-status { font-size: 0.75rem; color: var(--success); }

/* --- Main Content --- */
.main-content {
    flex: 1;
    margin-left: var(--sidebar-w);
    padding: 2rem;
}

.top-bar {
    position: sticky; top: 0; z-index: 50;
    background: rgba(6,6,15,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0 32px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-radius: 0;
    margin-bottom: 28px;
}

h1 { font-size: 1.5rem; }

.top-actions {
    display: flex;
    align-items: center;
    gap: 2rem;
    font-size: 0.9rem;
    color: var(--text-dim);
}

.btn-sync-quick {
    background: var(--accent);
    color: white;
    border: none;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 600;
}

/* --- Dashboard Widgets --- */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.stat-card {
    padding: 2rem;
    border-radius: 20px;
    background: var(--glass);
    border: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
    gap: 1.5rem;
}

.stat-card i {
    font-size: 2rem;
    color: var(--accent);
}

.stat-info h3 { font-size: 0.9rem; color: var(--text-dim); }
.stat-info p { font-size: 1.8rem; font-weight: 700; }

.quick-entry {
    padding: 2rem;
    border-radius: 24px;
    background: var(--glass);
    border: 1px solid var(--glass-border);
    margin-bottom: 2rem;
}

textarea {
    width: 100%;
    height: 120px;
    background: rgba(0,0,0,0.2);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 1rem;
    color: white;
    margin: 1.5rem 0;
    resize: none;
}

.entry-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.examples {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--text-dim);
}

.examples span {
    cursor: pointer;
    padding: 0.4rem 0.8rem;
    background: var(--glass);
    border-radius: 6px;
}

.examples span:hover { color: var(--accent); }

.system-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
}

.system-card {
    padding: 1.5rem;
    border-radius: 16px;
    background: var(--glass);
    border: 1px solid var(--glass-border);
    text-align: center;
    transition: transform 0.3s ease;
}

.system-card:hover { transform: translateY(-5px); border-color: var(--accent); }
.system-card i { font-size: 1.5rem; color: var(--accent); margin-bottom: 1rem; }
.system-card h4 { margin-bottom: 0.5rem; }
.system-card p { font-size: 0.8rem; color: var(--text-dim); }

/* --- Global Elements --- */
.view { display: none; }
.view.active { display: block; animation: fadeIn 0.4s ease; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

.animate-up { animation: fadeIn 0.6s ease forwards; }

/* --- Table Styles --- */
table th {
    text-align: left;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--text3);
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
}

table td {
    padding: 12px 14px;
    border-bottom: 1px solid rgba(255,255,255,0.02);
}

/* --- Badges --- */
.badge {
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0% { opacity: 1; }
    50% { opacity: 0.6; }
    100% { opacity: 1; }
}

/* --- Glass Input --- */
.glass-input:focus {
    border-color: var(--accent2) !important;
    outline: none;
    box-shadow: 0 0 10px var(--border);
}

/* Responsive */
@media (max-width: 1024px) {
    .stats-grid { grid-template-columns: 1fr; }
    .sidebar { width: 80px; }
    .sidebar span, .sidebar .user-info div { display: none; }
    .main-content { margin-left: 80px; }
}
